{
  "name": "veterinary-booking-system",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "android:clean": "expo start --clear --android",
    "android:debug": "cd android && gradlew.bat installDebug",
    "android:release": "cd android && gradlew.bat assembleRelease",
    "android:install-release": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "android:install-debug": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:reverse": "adb reverse tcp:3000 tcp:3000",
    "android:clean:full": "cd android && gradlew.bat clean",
    "android:clean:deep": "cd android && gradlew.bat clean && rd /s /q .gradle build app\\build && cd ..",
    "web": "expo start --web",
    "dev": "expo start --android",
    "build:android": "cd android && gradlew.bat assembleRelease",
    "doctor": "npx expo-doctor",
    "eas:login": "npx expo login",
    "eas:build": "npx eas build -p android",
    "clean:all": "rmdir /s /q node_modules android .expo dist && npm install",
    "adb": "adb devices",
    "adb:restart": "adb kill-server && adb start-server",
    "adb:logs": "adb logcat *:S ReactNative:V ReactNativeJS:V",
    "lint": "expo lint",
    "print:tree": "node scripts/print-repo-tree.js",
    "post:install": "node scripts/patch-css-interop.js",
    "typecheck": "tsc --noEmit",
    "check:no-console": "node scripts/check-no-console.js",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "date-fns": "^4.2.1",
    "date-fns-tz": "^3.2.0",
    "expo": "~55.0.25",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.7",
    "expo-glass-effect": "~55.0.11",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.15",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "nativewind": "^4.2.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-calendars": "^1.1314.0",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "autoprefixer": "^10.5.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.18",
    "postcss": "^8.5.14",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^3.3.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
